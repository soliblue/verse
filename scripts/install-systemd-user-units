#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${VERSE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

mkdir -p "$UNIT_DIR"

for UNIT in verse-server.service verse-nightjar.service verse-nightjar.timer 'verse-nightjar@.service'; do
  sed "s#__ROOT__#$ROOT#g" "$ROOT/scripts/systemd/$UNIT.in" > "$UNIT_DIR/$UNIT"
done

systemctl --user import-environment PATH
systemctl --user daemon-reload

printf '%s\n' \
  'Installed Verse user units.' \
  'Enable with: systemctl --user enable --now verse-server.service verse-nightjar.timer' \
  'Inspect with: systemctl --user status verse-server.service verse-nightjar.timer' \
  'Logs with: journalctl --user -u verse-server.service -u verse-nightjar.service -n 100'
