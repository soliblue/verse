#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${MORROW_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

mkdir -p "$UNIT_DIR"

for UNIT in morrow-server.service morrow-nightjar.service morrow-nightjar.timer; do
  sed "s#__ROOT__#$ROOT#g" "$ROOT/scripts/systemd/$UNIT.in" > "$UNIT_DIR/$UNIT"
done

systemctl --user import-environment PATH
systemctl --user daemon-reload

printf '%s\n' \
  'Installed Morrow user units.' \
  'Enable with: systemctl --user enable --now morrow-server.service morrow-nightjar.timer' \
  'Inspect with: systemctl --user status morrow-server.service morrow-nightjar.timer' \
  'Logs with: journalctl --user -u morrow-server.service -u morrow-nightjar.service -n 100'
