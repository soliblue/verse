#!/usr/bin/env bash
set -euo pipefail
umask 077

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${VERSE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
JOB="${1:-all}"
if [[ "$JOB" != "all" && "$JOB" != "articles" && "$JOB" != "events" ]]; then
  printf 'invalid nightjar job: %s\n' "$JOB" >&2
  exit 2
fi

if [[ -f "$ROOT/server/.env" ]]; then
  set -a
  source "$ROOT/server/.env"
  set +a
fi

RUNS_ROOT="${VERSE_RUNS_DIR:-runs}"
if [[ "$RUNS_ROOT" != /* ]]; then
  RUNS_ROOT="$ROOT/$RUNS_ROOT"
fi
RESULT_ROOT="$RUNS_ROOT/_nightjar"
TIMEOUT_SECONDS="${VERSE_NIGHTJAR_TIMEOUT_SECONDS:-14400}"
MODE="${VERSE_NIGHTJAR_MODE:-agent}"
mkdir -p "$RESULT_ROOT"

exec 9>"$RESULT_ROOT/nightjar.lock"
if ! flock -n 9; then
  printf 'nightjar already running\n'
  exit 0
fi

cd "$ROOT"

STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
RUN_DATE="${VERSE_RUN_DATE:-$(date -u +%F)}"
RUN_ID="nightjar-$JOB-$RUN_DATE"
RUN_DIR="$RESULT_ROOT/$STAMP"
PREFLIGHT_LOG="$RUN_DIR/preflight.log"
PIPELINE_LOG="$RUN_DIR/pipeline.log"
RESULT_FILE="$RUN_DIR/result.json"
AGENT_RESULT="$RUN_DIR/agent-result.json"
PROTOCOL_LOG="$RUN_DIR/agent-protocol.jsonl"
WORKSPACE="$RUN_DIR/workspace"
STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
mkdir -p "$RUN_DIR"
: > "$PIPELINE_LOG"

set +e
"$ROOT/scripts/nightjar-preflight" >"$PREFLIGHT_LOG" 2>&1
PREFLIGHT_STATUS=$?
set -e

if [[ "$PREFLIGHT_STATUS" -ne 0 ]]; then
  python3 "$ROOT/scripts/nightjar_result.py" \
    --path "$RESULT_FILE" \
    --status preflight_failed \
    --date "$RUN_DATE" \
    --run-id "$RUN_ID" \
    --started-at "$STARTED_AT" \
    --completed-at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --exit-code "$PREFLIGHT_STATUS" \
    --preflight-log "$PREFLIGHT_LOG" \
    --pipeline-log "$PIPELINE_LOG" \
    --mode "$MODE" \
    --agent-result "$AGENT_RESULT" \
    --protocol-log "$PROTOCOL_LOG" \
    --workspace "$WORKSPACE"
  cat "$PREFLIGHT_LOG"
  exit "$PREFLIGHT_STATUS"
fi

if [[ "$MODE" == "agent" ]]; then
  ARGS=(bash "$ROOT/scripts/nightjar-agent-run" "$ROOT" "$RUN_DATE" "$RUN_ID" "$RUN_DIR" "$JOB")
else
  ARGS=(
    python3 -m etl nightly
    --date "$RUN_DATE"
    --run-id "$RUN_ID"
    --sources "${VERSE_SOURCES_FILE:-etl/sources.json}"
  )
  if [[ "${VERSE_NIGHTJAR_FORCE:-0}" == "1" ]]; then
    ARGS+=(--force)
  fi
fi

set +e
timeout --signal=TERM --kill-after=60 "${TIMEOUT_SECONDS}s" "${ARGS[@]}" >"$PIPELINE_LOG" 2>&1
PIPELINE_STATUS=$?
set -e

STATUS=failed
if [[ "$PIPELINE_STATUS" -eq 0 ]]; then
  STATUS=completed
elif [[ "$PIPELINE_STATUS" -eq 124 ]]; then
  STATUS=timed_out
fi

python3 "$ROOT/scripts/nightjar_result.py" \
  --path "$RESULT_FILE" \
  --status "$STATUS" \
  --date "$RUN_DATE" \
  --run-id "$RUN_ID" \
  --started-at "$STARTED_AT" \
  --completed-at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --exit-code "$PIPELINE_STATUS" \
  --preflight-log "$PREFLIGHT_LOG" \
  --pipeline-log "$PIPELINE_LOG" \
  --mode "$MODE" \
  --agent-result "$AGENT_RESULT" \
  --protocol-log "$PROTOCOL_LOG" \
  --workspace "$WORKSPACE"

cat "$PIPELINE_LOG"
exit "$PIPELINE_STATUS"
