#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${VERSE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
IMAGE="${VERSE_AGENT_CONTAINER_IMAGE:-verse-nightjar-codex:0.144.1}"

sudo -n docker build \
  --build-arg CODEX_VERSION=0.144.1 \
  --file "$ROOT/scripts/nightjar-codex.Dockerfile" \
  --tag "$IMAGE" \
  "$ROOT"
