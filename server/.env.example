VERSE_DB_PATH=db/verse.sqlite
VERSE_DEVICE_SECRET=replace-with-a-long-random-device-secret
VERSE_ALLOW_UNAUTHENTICATED=0
VERSE_HOST=127.0.0.1
VERSE_PORT=8787
VERSE_AUTO_MIGRATE=1
VERSE_MAX_REQUEST_BYTES=65536
VERSE_CORS_ORIGINS=
VERSE_SOURCES_FILE=etl/sources.json
VERSE_RUNS_DIR=runs
VERSE_MIN_FREE_KB=1048576
VERSE_NIGHTJAR_AGENT=1
VERSE_NIGHTJAR_TIMEOUT_SECONDS=14400
VERSE_AGENT_TIMEOUT_SECONDS=10800
VERSE_AGENT_MODEL=
